# ─── Required ─────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here
ANTHROPIC_API_KEY=sk-ant-...

# ─── Slack direct push ────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXX

# ─── Mom (Slack push fallback via pi-mom) ─────────
MOM_EVENTS_DIR=/path/to/mom/data/events
MOM_CHANNEL_ID=C0XXXXXXX

# ─── Optional (fallback LLM + data sources) ──────
GEMINI_API_KEY=
BINANCE_API_KEY=                     # Reserved for Phase 3 trade execution
POLYGON_API_KEY=

# ─── Database ─────────────────────────────────────
DATABASE_PATH=./data/macro-sniper.db

# ─── LLM Configuration ───────────────────────────
LLM_MODEL_HEAVY=claude-opus-4-6
LLM_MODEL_FAST=gemini-3.1-flash-lite-preview
LLM_FALLBACK_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1

# ─── Application ─────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
