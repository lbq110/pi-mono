{
	"name": "@mariozechner/pi-macro-sniper",
	"version": "0.52.10",
	"description": "Macro liquidity, bond market, and crypto sentiment analysis for intelligent investment advisory",
	"type": "module",
	"bin": {
		"macro-sniper": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"drizzle",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && chmod +x dist/cli.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"check": "tsgo --noEmit -p tsconfig.build.json",
		"test": "vitest --run",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.52.10",
		"better-sqlite3": "^12.6.2",
		"commander": "^12.1.0",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"drizzle-orm": "^0.45.1",
		"node-cron": "^4.2.1",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.11",
		"@types/node-cron": "^3.0.11",
		"drizzle-kit": "^0.31.9",
		"pino-pretty": "^13.1.3",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"macro",
		"liquidity",
		"bonds",
		"crypto",
		"sentiment",
		"investment"
	],
	"author": "",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
